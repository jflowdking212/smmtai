# ============================================
# EE PostMind — Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- Database ---
DATABASE_URL=postgresql://postmind:password@localhost:5432/postmind
POSTGRES_USER=postmind
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=postmind

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# --- Encryption (64 hex chars = 32 bytes) ---
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
BILLING_GRACE_PERIOD_DAYS=7
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Email (optional, uses console logging when unset) ---
RESEND_API_KEY=
EMAIL_FROM=EE PostMind <no-reply@smmt.local>

# --- AI Service ---
AI_SERVICE_URL=http://localhost:8016
AI_SERVICE_KEY=your-internal-api-key

# --- Frontend URL ---
FRONTEND_URL=http://localhost:5173

# --- Background jobs ---
CONNECTION_HEALTH_CHECK_INTERVAL_MINUTES=60

# --- Social Platform OAuth ---
# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:4016/api/v1/connections/facebook/callback
# Instagram (uses Facebook app credentials)
INSTAGRAM_REDIRECT_URI=http://localhost:4016/api/v1/connections/instagram/callback
# Twitter/X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:4016/api/v1/connections/twitter/callback
# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4016/api/v1/connections/linkedin/callback
# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4016/api/v1/connections/tiktok/callback
# YouTube (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4016/api/v1/connections/youtube/callback
# Pinterest
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:4016/api/v1/connections/pinterest/callback
# Mastodon
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_REDIRECT_URI=http://localhost:4016/api/v1/connections/mastodon/callback

# --- Custom Platforms ---
# entreprenrs.com (WoWonder)
ENTREPRENRS_SERVER_KEY=
ENTREPRENRS_API_URL=https://entreprenrs.com/api
# chrxstians.com (Sngine)
CHRXSTIANS_API_URL=https://chrxstians.com/api
# iohah.com (Sngine)
IOHAH_API_URL=https://iohah.com/api

# --- Sentry (Error Monitoring) ---
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
VITE_SENTRY_DSN=

# --- Redis Cache URL ---
REDIS_URL=redis://localhost:6379
