# ============================================
# EE PostMind — Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- Database ---
DATABASE_URL=postgresql://postmind:password@localhost:5432/postmind
POSTGRES_USER=postmind
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=postmind

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# --- Encryption (64 hex chars = 32 bytes) ---
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
BILLING_GRACE_PERIOD_DAYS=7
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Email (optional, uses console logging when unset) ---
RESEND_API_KEY=
EMAIL_FROM=EE PostMind <no-reply@smmt.local>

# --- AI Service ---
AI_SERVICE_URL=http://localhost:8016
AI_SERVICE_KEY=your-internal-api-key

# --- Frontend URL ---
FRONTEND_URL=http://localhost:5173

# --- Background jobs ---
CONNECTION_HEALTH_CHECK_INTERVAL_MINUTES=60

# --- Social Platform OAuth ---
# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:4016/api/v1/connections/facebook/callback
# Instagram (uses Facebook app credentials)
INSTAGRAM_REDIRECT_URI=http://localhost:4016/api/v1/connections/instagram/callback
# Twitter/X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:4016/api/v1/connections/twitter/callback
# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4016/api/v1/connections/linkedin/callback
# Optional LinkedIn REST API version header (YYYYMM)
LINKEDIN_API_VERSION=202511
# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4016/api/v1/connections/tiktok/callback
# Optional override (default includes publish scope)
TIKTOK_AUTH_SCOPE=user.info.profile,user.info.stats,video.list,video.publish
# Optional: keep false for browser-only publishing. true enables TikTok MEDIA_UPLOAD fallback (mobile app flow).
TIKTOK_ENABLE_MEDIA_UPLOAD_FALLBACK=false
# Optional: serve TikTok PULL_FROM_URL media through your verified domain.
TIKTOK_MEDIA_PROXY_ENABLED=true
TIKTOK_MEDIA_PROXY_BASE_URL=http://localhost:5173
TIKTOK_MEDIA_PROXY_TTL_SECONDS=3600
# Optional: wait for TikTok async publish status before marking as published.
TIKTOK_PUBLISH_STATUS_POLL_ATTEMPTS=6
TIKTOK_PUBLISH_STATUS_POLL_DELAY_MS=5000
# YouTube (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4016/api/v1/auth/oauth/google/callback
YOUTUBE_REDIRECT_URI=http://localhost:4016/api/v1/connections/youtube/callback
# GitHub login
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4016/api/v1/auth/oauth/github/callback
# Pinterest
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:4016/api/v1/connections/pinterest/callback
# Optional: use https://api-sandbox.pinterest.com for Trial apps
PINTEREST_API_BASE_URL=https://api.pinterest.com
# Mastodon
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_REDIRECT_URI=http://localhost:4016/api/v1/connections/mastodon/callback

# --- Custom Platforms ---
# entreprenrs.com (WoWonder)
ENTREPRENRS_ACCESS_TOKEN=
ENTREPRENRS_SERVER_KEY=
ENTREPRENRS_API_URL=https://entreprenrs.com/api
# chrxstians.com (Sngine)
CHRXSTIANS_API_KEY=
CHRXSTIANS_API_SECRET=
CHRXSTIANS_ACCESS_TOKEN=
CHRXSTIANS_BASE_URL=https://chrxstians.com
CHRXSTIANS_API_URL=https://chrxstians.com/api
# Optional: override publish/analytics route(s) when instance does not expose default signed routes.
# CHRXSTIANS_PUBLISH_ENDPOINT=/apis/php/posts/create
# CHRXSTIANS_PUBLISH_ENDPOINTS=/apis/php/posts/create,https://chrxstians.com/apis/php/post/create
# CHRXSTIANS_ANALYTICS_ENDPOINT=/apis/php/posts/{postId}/analytics
# CHRXSTIANS_ANALYTICS_ENDPOINTS=/apis/php/posts/{postId}/analytics,/apis/php/posts/{postId}
CHRXSTIANS_PUBLISH_ENDPOINT=
CHRXSTIANS_PUBLISH_ENDPOINTS=
CHRXSTIANS_ANALYTICS_ENDPOINT=
CHRXSTIANS_ANALYTICS_ENDPOINTS=
# iohah.com (Sngine)
IOHAH_API_KEY=
IOHAH_API_SECRET=
IOHAH_ACCESS_TOKEN=
IOHAH_BASE_URL=https://iohah.com
IOHAH_API_URL=https://iohah.com/api
# Optional: override post publish route(s) when instance does not expose default signed routes.
# Use absolute URLs, relative API paths, or comma-separated multiple candidates.
# Examples:
# IOHAH_PUBLISH_ENDPOINT=/api/posts
# IOHAH_PUBLISH_ENDPOINTS=/api/posts,https://iohah.com/apis/php/post/create
IOHAH_PUBLISH_ENDPOINT=
IOHAH_PUBLISH_ENDPOINTS=

# --- Sentry (Error Monitoring) ---
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
VITE_SENTRY_DSN=

# --- Redis Cache URL ---
REDIS_URL=redis://localhost:6379
