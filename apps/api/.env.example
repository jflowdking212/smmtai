# EE PostMind API
PORT=4016
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postmind:postmind@localhost:5432/ee_postmind?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"
RATE_LIMIT_USE_REDIS="true"
RATE_LIMIT_AUTH_WINDOW_MS="900000"
RATE_LIMIT_AUTH_MAX="20"
RATE_LIMIT_API_WINDOW_MS="60000"
RATE_LIMIT_API_MAX="100"

# JWT
JWT_SECRET="change-me-in-production-use-strong-secret"
JWT_REFRESH_SECRET="change-me-in-production-use-another-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
BILLING_GRACE_PERIOD_DAYS="7"

# OpenAI
OPENAI_API_KEY=""

# AI service
AI_SERVICE_URL="http://localhost:8016"
AI_SERVICE_KEY="dev-key"

# Email
RESEND_API_KEY=""
EMAIL_FROM="EE PostMind <no-reply@smmt.local>"

# AWS S3
AWS_S3_BUCKET=""
AWS_S3_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
MEDIA_UPLOAD_DIR="uploads"

# OAuth (Social Login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4016/api/v1/auth/oauth/google/callback"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:4016/api/v1/auth/oauth/github/callback"
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_CALLBACK_URL="http://localhost:4016/api/v1/auth/oauth/facebook/callback"
FACEBOOK_REDIRECT_URI="http://localhost:4016/api/v1/connections/facebook/callback"
INSTAGRAM_REDIRECT_URI="http://localhost:4016/api/v1/connections/instagram/callback"
TWITTER_REDIRECT_URI="http://localhost:4016/api/v1/connections/twitter/callback"
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:4016/api/v1/connections/linkedin/callback"
LINKEDIN_API_VERSION="202511"
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="http://localhost:4016/api/v1/connections/tiktok/callback"
TIKTOK_AUTH_SCOPE="user.info.profile,user.info.stats,video.list,video.publish"
TIKTOK_ENABLE_MEDIA_UPLOAD_FALLBACK="false"
TIKTOK_MEDIA_PROXY_ENABLED="true"
TIKTOK_MEDIA_PROXY_BASE_URL="http://localhost:5173"
TIKTOK_MEDIA_PROXY_TTL_SECONDS="3600"
TIKTOK_PUBLISH_STATUS_POLL_ATTEMPTS="6"
TIKTOK_PUBLISH_STATUS_POLL_DELAY_MS="5000"
YOUTUBE_REDIRECT_URI="http://localhost:4016/api/v1/connections/youtube/callback"
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""
PINTEREST_REDIRECT_URI="http://localhost:4016/api/v1/connections/pinterest/callback"
PINTEREST_API_BASE_URL="https://api.pinterest.com"
MASTODON_INSTANCE_URL="https://mastodon.social"
MASTODON_CLIENT_ID=""
MASTODON_REDIRECT_URI="http://localhost:4016/api/v1/connections/mastodon/callback"

# Frontend URL
FRONTEND_URL="http://localhost:5173"

# Notification scheduling
UPCOMING_NOTIFICATION_LEAD_MINUTES="60"
ANALYTICS_REPORT_TIMEZONE="UTC"
ANALYTICS_WEEKLY_REPORT_CRON="0 9 * * 1"
ANALYTICS_MONTHLY_REPORT_CRON="0 9 1 * *"
CONNECTION_HEALTH_CHECK_INTERVAL_MINUTES="60"
