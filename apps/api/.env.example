# EE PostMind API
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postmind:postmind@localhost:5432/ee_postmind?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production-use-strong-secret"
JWT_REFRESH_SECRET="change-me-in-production-use-another-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# OpenAI
OPENAI_API_KEY=""

# AWS S3
AWS_S3_BUCKET=""
AWS_S3_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# OAuth (Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# Frontend URL
FRONTEND_URL="http://localhost:5173"
