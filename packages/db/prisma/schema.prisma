// Prisma Schema for EE PostMind

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// User & Auth
// ============================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String?
  avatar          String?
  bio             String?
  timezone        String    @default("UTC")
  phone           String?
  country         String?
  profileComplete Boolean   @default(false) @map("profilecomplete")
  emailVerified   Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  refreshTokens  RefreshToken[]
  workspaces     WorkspaceMember[]
  ownedWorkspaces Workspace[]    @relation("WorkspaceOwner")
  posts          Post[]
  oauthAccounts  OAuthAccount[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  feedbacks      Feedback[]
  adminAuditLogs AdminAuditLog[]
  createdCoupons Coupon[] @relation("CouponCreator")
  couponRedemptions CouponRedemption[]

  // User Intelligence & Engagement Loop
  intelligenceProfile     UserIntelligenceProfile?
  voiceModel              UserVoiceModel?
  editHistory             UserEditHistory[]
  engagementHistory       UserEngagementHistory[]
  engagementSnapshots     UserEngagementSnapshot[]
  strategyRecommendations UserStrategyRecommendation[]
  competitorAccounts      CompetitorAccount[]

  @@map("users")
}

model OAuthAccount {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // google, github, facebook
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ============================================================
// Workspace & Teams
// ============================================================

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner             User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members           WorkspaceMember[]
  subscription      Subscription?
  socialConnections SocialConnection[]
  posts             Post[]
  templates         Template[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String  @id @default(cuid())
  userId      String?
  workspaceId String
  role        String  @default("creator") // owner, manager, creator, viewer
  status      String  @default("active")  // active, pending
  inviteEmail String?                       // email used for pending invites
  invitedBy   String?                       // userId of who sent the invite
  inviteToken String?                       // JWT token for the invite

  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

// ============================================================
// Subscriptions & Billing
// ============================================================

model Subscription {
  id                   String    @id @default(cuid())
  workspaceId          String    @unique
  tier                 String    @default("basic") // basic, pro, business, enterprise
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  status               String    @default("active") // active, past_due, canceled, trialing
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  usageRecords UsageRecord[]

  @@map("subscriptions")
}

model UsageRecord {
  id             String   @id @default(cuid())
  subscriptionId String
  metric         String   // posts, ai_generations, social_accounts
  count          Int      @default(0)
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, metric, periodStart])
  @@map("usage_records")
}

model Coupon {
  id                     String   @id @default(cuid())
  code                   String   @unique
  name                   String
  description            String?
  isActive               Boolean  @default(true)
  discountPercent        Int?
  freeDurationDays       Int?
  discountDurationMonths Int?
  maxTotalUses           Int?
  maxUniqueUsers         Int?
  requireCardForFreeCheckout Boolean @default(true)
  maxUsesPerUser         Int      @default(1)
  allowedPriceKeys       String[] @default([])
  defaultPriceKey        String?
  startsAt               DateTime?
  endsAt                 DateTime?
  redemptionCount        Int      @default(0)
  createdById            String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  createdBy   User?              @relation("CouponCreator", fields: [createdById], references: [id], onDelete: SetNull)
  redemptions CouponRedemption[]

  @@index([isActive, startsAt, endsAt])
  @@map("coupons")
}

model CouponRedemption {
  id                 String   @id @default(cuid())
  couponId           String
  userId             String
  workspaceId        String?
  priceKey           String
  status             String   @default("pending") // pending, redeemed, expired
  checkoutSessionId  String?  @unique
  reservationExpiresAt DateTime?
  redeemedAt         DateTime?
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([couponId, status, reservationExpiresAt])
  @@index([couponId, userId, status])
  @@index([workspaceId])
  @@map("coupon_redemptions")
}

// ============================================================
// Social Connections
// ============================================================

model SocialConnection {
  id           String    @id @default(cuid())
  workspaceId  String
  platform     String    // facebook, instagram, tiktok, linkedin, twitter, youtube, pinterest, bluesky, mastodon, telegram, entreprenrs, chrxstians, iohah
  accountName  String
  accountId    String
  accessToken  String    // encrypted (AES-256-GCM)
  refreshToken String?   // encrypted
  tokenExpiry  DateTime?
  metadata     Json?     // platform-specific data (instance URL for Mastodon, bot token for Telegram, etc.)
  isActive     Boolean   @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platformPosts PlatformPost[]

  @@unique([workspaceId, platform, accountId])
  @@map("social_connections")
}

// ============================================================
// Posts & Publishing
// ============================================================

model Post {
  id          String    @id @default(cuid())
  workspaceId String
  authorId    String
  content     String
  platforms   String[]  // target platforms
  status      String    @default("draft") // draft, scheduled, publishing, published, failed
  scheduledAt DateTime?
  publishedAt DateTime?
  designData  Json?     // Fabric.js canvas JSON
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id])
  media         Media[]
  platformPosts PlatformPost[]
  schedule      Schedule?
  contentPlanPosts ContentPlanPost[]

  @@index([workspaceId, status])
  @@index([scheduledAt])
  @@map("posts")
}

model Media {
  id       String @id @default(cuid())
  postId   String
  url      String
  type     String // image, video, gif
  width    Int?
  height   Int?
  fileSize Int?
  mimeType String?
  order    Int    @default(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("media")
}

model PlatformPost {
  id                 String    @id @default(cuid())
  postId             String
  socialConnectionId String
  platform           String
  platformPostId     String?   // ID returned by the platform after publishing
  url                String?
  status             String    @default("pending") // pending, publishing, published, failed
  error              String?
  publishedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  post             Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialConnection SocialConnection  @relation(fields: [socialConnectionId], references: [id])
  analytics        AnalyticsSnapshot[]

  @@index([platform, status])
  @@map("platform_posts")
}

// ============================================================
// Scheduling
// ============================================================

model Schedule {
  id        String    @id @default(cuid())
  postId    String    @unique
  cronExpr  String?   // for recurring posts
  timezone  String    @default("UTC")
  nextRunAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([nextRunAt, isActive])
  @@map("schedules")
}

// ============================================================
// Analytics
// ============================================================

model AnalyticsSnapshot {
  id             String   @id @default(cuid())
  platformPostId String
  impressions    Int      @default(0)
  reach          Int      @default(0)
  likes          Int      @default(0)
  comments       Int      @default(0)
  shares         Int      @default(0)
  clicks         Int      @default(0)
  saves          Int      @default(0)
  engagementRate Float    @default(0)
  metadata       Json?    // platform-specific metrics
  capturedAt     DateTime @default(now())

  platformPost PlatformPost @relation(fields: [platformPostId], references: [id], onDelete: Cascade)

  @@index([platformPostId, capturedAt])
  @@map("analytics_snapshots")
}

// ============================================================
// Templates
// ============================================================

model Template {
  id          String   @id @default(cuid())
  workspaceId String?  // null = system template
  name        String
  category    String   // business, food, fashion, tech, fitness, travel, ecommerce, motivational, event
  thumbnail   String?
  designData  Json     // Fabric.js canvas JSON
  platforms   String[] // compatible platforms
  isPremium   Boolean  @default(false)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([category, isSystem])
  @@map("templates")
}

// ============================================================
// Feedback
// ============================================================

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("general") // bug, feature, general
  message   String
  rating    Int?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("feedbacks")
}

// ============================================================
// System Configuration (admin-managed key-value settings)
// ============================================================

model SystemConfig {
  key       String   @id
  value     String
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

// ============================================================
// Admin Audit Log
// ============================================================

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // e.g. "user.suspend", "user.upgrade", "plan.update", "settings.smtp"
  targetType String?  // e.g. "user", "plan", "settings"
  targetId   String?
  details    Json?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([action])
  @@map("admin_audit_logs")
}

// ============================================================
// AI Chat & Knowledge Base
// ============================================================

enum ConversationStatus {
  ACTIVE
  ENDED
  TRANSFERRED
}

model ChatConversation {
  id             String             @id @default(cuid())
  sessionId      String             @unique
  customerName   String?
  customerEmail  String?
  customerPhone  String?
  messages       Json
  summary        String?
  status         ConversationStatus @default(ACTIVE)
  transferredTo  String?
  transferReason String?
  tags           String[]
  sentiment      String?
  startedAt      DateTime           @default(now())
  endedAt        DateTime?
  updatedAt      DateTime           @updatedAt

  @@index([customerEmail])
  @@index([status])
  @@map("chat_conversations")
}

model KnowledgeBase {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String?
  tags      String[]
  embedding Float[]
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("knowledge_base")
}


// ============================================================
// Trend Engine Models
// ============================================================

model Trend {
  id               String    @id @default(cuid())
  topic            String
  normalizedTopic  String?
  category         String?
  platform         String
  score            Int       @default(0)
  engagementCount  Int       @default(0)
  growthRate       Float?    @default(0)
  trendStatus      String    @default("Emerging")
  sentiment        String?   @default("neutral")
  sourceUrl        String?
  competitionLevel Float?    @default(0.5)
  viralProbability Float?    @default(0)
  peakTimeEstimate DateTime?
  lifespanDays     Int?
  country          String?
  region           String?
  isNsfw           Boolean   @default(false)
  isBlacklisted    Boolean   @default(false)
  isFlagged        Boolean   @default(false)
  flagReason       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  savedBy          SavedTrend[]

  @@unique([topic, platform])
  @@index([category])
  @@index([createdAt])
  @@index([platform])
  @@index([trendStatus])
  @@map("trends")
}

model SavedTrend {
  id      String   @id @default(cuid())
  userId  String
  trendId String
  savedAt DateTime @default(now())

  trend   Trend    @relation(fields: [trendId], references: [id], onDelete: Cascade)

  @@unique([userId, trendId])
  @@index([userId])
  @@map("saved_trends")
}

model TrendBlacklist {
  id        String   @id @default(cuid())
  keyword   String   @unique
  reason    String?
  addedBy   String?
  createdAt DateTime @default(now())

  @@map("trend_blacklist")
}

model UserTrendPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  preferredCategories String[] @default([])
  preferredPlatforms  String[] @default([])
  blockedCategories   String[] @default([])
  region              String?
  country             String?
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  @@map("user_trend_preferences")
}

// ============================================================
// Content Planning Engine
// ============================================================

model ContentPlan {
  id              String   @id @default(cuid())
  workspaceId     String
  userId          String
  theme           String
  tone            String   @default("professional")
  dateRangeStart  DateTime
  dateRangeEnd    DateTime
  parsedIntent    Json?    // Stores the ParsedIntent interface
  status          String   @default("draft") // draft, generating, ready, partial, authorized, cancelled
  authorizedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posts           ContentPlanPost[]

  @@index([workspaceId])
  @@index([userId])
  @@map("content_plans")
}

model ContentPlanPost {
  id               String   @id @default(cuid())
  planId           String
  platform         String
  contentBody      String   @db.Text
  hashtags         String[] @default([])
  mediaSuggestion  String?  @db.Text
  mediaUrls        String[] @default([])
  mediaSource      String?  // 'upload', 'editor', or null
  characterCount   Int      @default(0)
  scheduledAt      DateTime
  status           String   @default("pending_review") // pending_review, approved, scheduled, posted, failed
  aiModelUsed      String
  regenerated      Boolean  @default(false)
  editedByUser     Boolean  @default(false)
  editorDesignData Json?
  postId           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  plan             ContentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  post             Post?       @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@index([postId])
  @@map("content_plan_posts")
}

// ============================================================
// User Intelligence & Engagement Loop
// ============================================================

model UserIntelligenceProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  niche              String?                // e.g. "fitness coaching", "SaaS marketing"
  targetAudience     Json?                  // { demographics, painPoints, aspirations }
  contentPillars     String[] @default([])  // ["motivation", "tips", "behind-the-scenes"]
  tonePreference     String?                // "professional", "casual", "inspirational"
  avoidedTopics      String[] @default([])  // topics the user never wants
  goals              Json?                  // { primary: "grow followers", secondary: "drive traffic" }
  postingPreferences Json?                  // { preferredDays: [], preferredTimes: [], frequency: "daily" }
  brandKeywords      String[] @default([])  // branded hashtags, key phrases
  completenessScore  Int      @default(0)   // 0–100
  sourceData         Json?                  // tracks which fields came from onboarding vs progressive
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_intelligence_profiles")
}

model UserVoiceModel {
  id                 String   @id @default(cuid())
  userId             String   @unique
  formalityScore     Float    @default(0.5)  // 0 = very casual, 1 = very formal
  energyScore        Float    @default(0.5)  // 0 = calm, 1 = high energy
  avgSentenceLength  Float?                  // words per sentence
  vocabularySamples  Json?                   // { preferredWords: [], avoidedWords: [] }
  emojiUsageRate     Float    @default(0)    // emojis per 100 words
  ctaStyle           String?                 // "direct", "soft", "question-based"
  hashtagPatterns    Json?                   // { avgCount: 5, preferred: ["#fitness", "#mindset"] }
  confidenceScore    Float    @default(0)    // 0–1, how mature the voice model is
  samplesAnalyzed    Int      @default(0)    // number of edits processed
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_voice_models")
}

model UserEditHistory {
  id              String   @id @default(cuid())
  userId          String
  postId          String?
  originalContent String   @db.Text     // AI-generated original
  editedContent   String   @db.Text     // User's final version
  diffSummary     Json?                 // { additions: [], removals: [], toneShift: "more casual" }
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_edit_history")
}

model UserEngagementHistory {
  id              String   @id @default(cuid())
  userId          String
  postId          String?
  platform        String                    // "facebook", "instagram", etc.
  contentType     String?                   // "carousel", "reel", "text", "image", "video"
  topic           String?                   // extracted topic/pillar
  postingHour     Int?                      // 0–23, hour posted
  postingDay      Int?                      // 0–6, day of week
  likes           Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  saves           Int      @default(0)
  reach           Int      @default(0)
  impressions     Int      @default(0)
  clickThroughs   Int      @default(0)
  engagementRate  Float    @default(0)      // (likes+comments+shares+saves)/reach*100
  collectedAt     DateTime @default(now())
  snapshotType    String   @default("2h")   // "2h", "24h", "7d"
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
  @@index([userId, createdAt])
  @@map("user_engagement_history")
}

model UserEngagementSnapshot {
  id              String   @id @default(cuid())
  userId          String
  weekStart       DateTime
  platform        String
  avgEngRate      Float    @default(0)
  totalReach      Int      @default(0)
  totalPosts      Int      @default(0)
  topContentType  String?
  topTopic        String?
  topPostingHour  Int?
  metadata        Json?                   // analysis results from pattern analyzer
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart, platform])
  @@index([userId])
  @@map("user_engagement_snapshots")
}

model UserStrategyRecommendation {
  id              String    @id @default(cuid())
  userId          String
  type            String                    // "timing", "content_type", "topic", "audience", "profile_nudge", "ab_test", "growth"
  title           String                    // "Your carousels get 3x more saves"
  body            String    @db.Text        // Full recommendation text
  priority        Int       @default(0)     // 0=normal, 1=high, 2=critical
  status          String    @default("pending") // "pending", "acted", "dismissed"
  actionedAt      DateTime?
  expiresAt       DateTime?
  metadata        Json?                     // { metric: "saves", value: 3.2, comparison: "vs image posts" }
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("user_strategy_recommendations")
}

// Enhancement 1: Competitor Benchmarking
model CompetitorAccount {
  id              String   @id @default(cuid())
  userId          String
  platform        String                    // "instagram", "twitter", etc.
  handle          String                    // @competitor_handle
  displayName     String?
  followerCount   Int?                      // last known follower count
  avgEngRate      Float?                    // estimated avg engagement rate
  lastCheckedAt   DateTime?
  metadata        Json?                     // historical snapshots, growth rate
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, handle])
  @@index([userId])
  @@map("competitor_accounts")
}
